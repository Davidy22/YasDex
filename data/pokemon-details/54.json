een":[60,94,95,113,193,238,248,287],"egg_diamond-pearl":[60,94,95,109,113,193,238,248,281,287,426],"egg_platinum":[60,94,95,109,113,193,238,248,281,287,426],"egg_heartgold-soulsilver":[60,94,95,109,113,193,227,238,248,281,287,426],"egg_black-white":[60,95,109,193,214,227,238,248,281,287,290,426,485],"egg_black-2-white-2":[60,95,109,193,214,227,238,248,281,287,290,426,485],"egg_x-y":[60,95,109,193,214,227,238,248,281,287,290,426,485,493,499],"egg_omega-ruby-alpha-sapphire":[60,95,109,193,214,227,238,248,281,287,290,426,485,493,499],"egg_sun-moon":[60,95,109,193,214,227,238,248,281,287,290,426,485,493,499],"egg_ultra-sun-ultra-moon":[60,95,109,193,214,227,238,248,281,287,290,426,485,493,499],"egg_sword-shield":[60,95,109,238,281,493,499],"egg_brilliant-diamond-shining-pearl":[60,95,109,227,238,248,281,493,499],"egg_scarlet-violet":[60,95,109,238,281,493,499]},"species":"psyduck","gen":"generation-i","leg":false,"myth":false,"baby":false,"eggs":["Water 1","Field"],"flavor":[{"version":"red","text":"While lulling its enemies with its vacant look, this wily POK\u00e9MON will use psychokinetic powers."},{"version":"blue","text":"While lulling its enemies with its vacant look, this wily POK\u00e9MON will use psychokinetic powers."},{"version":"yellow","text":"Always tormented by headaches. It uses psychic powers, but it is not known if it intends to do so."},{"version":"gold","text":"It has mystical powers but doesn't recall that it has used them. That is why it always looks puzzled."},{"version":"silver","text":"If its chronic headache peaks, it may exhibit odd powers. It seems unable to recall such an episode."},{"version":"crystal","text":"The only time it can use its psy\u00ad chic power is when its sleeping brain cells happen to wake."},{"version":"ruby","text":"PSYDUCK uses a mysterious power. When it does so, this POK\u00e9MON  generates brain waves that are supposedly only seen in sleepers. This discovery spurred controversy among scholars."},{"version":"sapphire","text":"If it uses its mysterious power, PSYDUCK can\u2019t remember having done so. It apparently can\u2019t form a memory of such an event because it goes into an altered state that is much like deep sleep."},{"version":"emerald","text":"When its headache intensifies, it starts using strange powers. However, it has no recollection of its powers, so it always looks befuddled and bewildered."},{"version":"firered","text":"It is constantly wracked by a headache. When the headache turns intense, it begins using mysterious powers."},{"version":"leafgreen","text":"While lulling its enemies with its vacant look, this wily POK\u00e9MON will use psychokinetic powers."},{"version":"diamond","text":"If its usual headache worsens, it starts exhibiting odd powers. It can\u2019t remember doing so, however."},{"version":"pearl","text":"It never remembers using its odd powers, so it always tilts its head in puzzlement."},{"version":"platinum","text":"Overwhelmed by enigmatic abilities, it suffers a constant headache. It sometimes uses mysterious powers."},{"version":"heartgold","text":"It has mystical powers but doesn\u2019t recall that it has used them. That is why it always looks puzzled."},{"version":"soulsilver","text":"If its chronic headache peaks, it may exhibit odd powers. It seems unable to recall such an episode."},{"version":"black","text":"Overwhelmed by enigmatic abilities, it suffers a constant headache. It sometimes uses mysterious powers."},{"version":"white","text":"Overwhelmed by enigmatic abilities, it suffers a constant headache. It sometimes uses mysterious powers."},{"version":"black-2","text":"When headaches stimulate its brain cells, which are usually inactive, it can use a mysterious power."},{"version":"white-2","text":"When headaches stimulate its brain cells, which are usually inactive, it can use a mysterious power."},{"version":"x","text":"It is constantly wracked by a headache. When the headache turns intense, it begins using mysterious powers."},{"version":"y","text":"It has mystical powers but doesn\u2019t recall that it has used them. That is why it always looks puzzled."},{"version":"omega-ruby","text":"Psyduck uses a mysterious power. When it does so, this Pok\u00e9mon generates brain waves that are supposedly only seen in sleepers. This discovery spurred controversy among scholars."},{"version":"alpha-sapphire","text":"If it uses its mysterious power, Psyduck can\u2019t remember having done so. It apparently can\u2019t form a memory of such an event because it goes into an altered state that is much like deep sleep."},{"version":"sun","text":"As a result of headaches so fierce they cause it to cry, it sometimes uses psychokinesis without meaning to."},{"version":"moon","text":"This Pok\u00e9mon is troubled by constant headaches. The more pain it\u2019s in, the more powerful its psychokinesis becomes."},{"version":"ultra-sun","text":"Using psychokinesis gives it a headache, so it normally passes the time spacing out and doing as little as possible."},{"version":"ultra-moon","text":"It has been found that its brain cells are 10 times more active when Psyduck is experiencing a headache."},{"version":"lets-go-pikachu","text":"Always tormented by headaches. It uses psychic powers, but whether it intends to do so is not known."},{"version":"lets-go-eevee","text":"Always tormented by headaches. It uses psychic powers, but whether it intends to do so is not known."},{"version":"sword","text":"Psyduck is constantly beset by headaches. If the Pok\u00e9mon lets its strange power erupt, apparently the pain subsides for a while."},{"version":"shield","text":"As Psyduck gets stressed out, its headache gets progressively worse. It uses intense psychic energy to overwhelm those around it."},{"version":"legends-arceus","text":"Suffers perpetual headaches. If the agony grows too great, Psyduck's latent power erupts, contrary to Psyduck's intent. Ergo, I am exploring ways to ease the pain."}],"evo":{"name":"psyduck","level":0,"min_level":null,"trigger":null,"item":null,"held_item":null,"known_move":null,"known_move_type":null,"location":null,"min_affection":null,"min_beauty":null,"min_happiness":null,"needs_overworld_rain":false,"time_of_day":null,"turn_upside_down":false,"evolves_to":[{"name":"golduck","level":1,"min_level":33,"trigger":"level-up","item":null,"held_item":null,"known_move":null,"known_move_type":null,"location":null,"min_affection":null,"min_beauty":null,"min_happiness":null,"needs_overworld_rain":false,"time_of_day":"","turn_upside_down":false,"evolves_to":[]}]},"sprite":"https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/54.png","shiny":"https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/shiny/54.png","capture":190,"happiness":70,"growth":"medium","gender":4,"hatch":20,"ev":{"special_attack":1},"forms":[]}