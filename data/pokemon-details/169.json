illiant-diamond-shining-pearl":[[44,34],[48,1],[71,1],[92,1],[103,1],[109,55],[114,41],[141,69],[212,1],[305,15],[310,1],[314,27],[366,1],[403,62],[440,0],[440,1],[474,48],[501,20]],"tutor_platinum":[129,173,239,253,257,314,428,466],"tutor_heartgold-soulsilver":[129,143,162,173,239,253,257,314,366,428,466],"tutor_black-2-white-2":[143,162,173,202,214,253,257,289,355,366,399,428],"tutor_omega-ruby-alpha-sapphire":[143,162,173,202,253,257,289,366,428],"tutor_ultra-sun-ultra-moon":[143,162,173,202,253,257,289,366,428,432],"tutor_sword-shield":[814]},"species":"crobat","gen":"generation-ii","leg":false,"myth":false,"baby":false,"eggs":["flying"],"flavor":[{"version":"gold","text":"It flies so si\u00ad lently through the dark on its four wings that it may not be noticed even when nearby."},{"version":"silver","text":"The development of wings on its legs enables it to fly fast but also makes it tough to stop and rest."},{"version":"crystal","text":"As a result of its pursuit of faster, yet more silent flight, a new set of wings grew on its hind legs."},{"version":"ruby","text":"If this POK\u00e9MON is flying by fluttering only a pair of wings on either the forelegs or hind legs, it\u2019s proof that CROBAT has been flying a long distance. It switches the wings it uses if it is tired."},{"version":"sapphire","text":"CROBAT sneaks up on its intended prey using wings that barely make a sound. This POK\u00e9MON rests by hanging on a tree branch with its rear legs that serve as wings."},{"version":"emerald","text":"Over the course of evolution, its hind legs turned into wings. By alternately resting its front and rear wings, it can fly all day without having to stop."},{"version":"firered","text":"The development of wings on its legs enables it to fly fast but also makes it tough to stop and rest."},{"version":"leafgreen","text":"It flies so silently through the dark on its four wings that it may not be noticed even when nearby."},{"version":"diamond","text":"Having four wings enables it to fly faster and more quietly. It turns active when the night comes."},{"version":"pearl","text":"A Pok\u00e9mon that gained vastly enhanced flying performance by having its legs turn into wings."},{"version":"platinum","text":"The transformation of its legs into wings made it better at flying, but more clumsy at walking."},{"version":"heartgold","text":"It flies so silently through the dark on its four wings that it may not be noticed even when nearby."},{"version":"soulsilver","text":"The development of wings on its legs enables it to fly fast but also makes it tough to stop and rest."},{"version":"black","text":"The transformation of its legs into wings made it better at flying, but more clumsy at walking."},{"version":"white","text":"The transformation of its legs into wings made it better at flying, but more clumsy at walking."},{"version":"black-2","text":"Having four wings allows it to fly more quickly and quietly so it can sneak up on prey without its noticing."},{"version":"white-2","text":"Having four wings allows it to fly more quickly and quietly so it can sneak up on prey without its noticing."},{"version":"x","text":"It flies so silently through the dark on its four wings that it may not be noticed even when nearby."},{"version":"y","text":"Having four wings allows it to fly more quickly and quietly so it can sneak up on prey without its noticing."},{"version":"omega-ruby","text":"If this Pok\u00e9mon is flying by fluttering only a pair of wings on either the forelegs or hind legs, it\u2019s proof that Crobat has been flying a long distance. It switches the wings it uses if it is tired."},{"version":"alpha-sapphire","text":"Crobat sneaks up on its intended prey using wings that barely make a sound. This Pok\u00e9mon rests by hanging on a tree branch with its rear legs that serve as wings."},{"version":"sun","text":"Both its legs became wings, and as a result, it can\u2019t move well on the ground. All it can do is crawl around."},{"version":"moon","text":"Silent and swift in its four-winged flight, it bites down on its prey before they realize what\u2019s happening. In a heartbeat, it drains their blood."},{"version":"ultra-sun","text":"Its fangs are so sharp, if it bites you in the dark and sucks your blood, you won\u2019t notice any pain or realize you\u2019ve been bitten."},{"version":"ultra-moon","text":"It feeds on the blood of living people and Pok\u00e9mon. If it can\u2019t drink any blood for even a short while, it becomes weak and unable to fly."},{"version":"sword","text":"Both of its legs have turned into wings. Without a sound, Crobat flies swiftly toward its prey and sinks its fangs into the nape of its target\u2019s neck."},{"version":"shield","text":"This Pok\u00e9mon flaps its four wings skillfully. Crobat can fly through cramped caves without needing to slow down."},{"version":"legends-arceus","text":"Its hind limbs have become another set of wings. Crobat expertly maneuvers its four wings to dart in exquisite fashion through even the most confined caves without losing any speed."}],"evo":{"name":"zubat","level":0,"min_level":null,"trigger":null,"item":null,"held_item":null,"known_move":null,"known_move_type":null,"location":null,"min_affection":null,"min_beauty":null,"min_happiness":null,"needs_overworld_rain":false,"time_of_day":null,"turn_upside_down":false,"evolves_to":[{"name":"golbat","level":1,"min_level":22,"trigger":"level-up","item":null,"held_item":null,"known_move":null,"known_move_type":null,"location":null,"min_affection":null,"min_beauty":null,"min_happiness":null,"needs_overworld_rain":false,"time_of_day":"","turn_upside_down":false,"evolves_to":[{"name":"crobat","level":2,"min_level":null,"trigger":"level-up","item":null,"held_item":null,"known_move":null,"known_move_type":null,"location":null,"min_affection":null,"min_beauty":null,"min_happiness":160,"needs_overworld_rain":false,"time_of_day":"","turn_upside_down":false,"evolves_to":[]}]}]},"sprite":"https://raw.git