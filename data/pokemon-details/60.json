 more adept at swimming than walking."},{"version":"lets-go-eevee","text":"The direction of the spiral on the belly differs by area. It is more adept at swimming than walking."},{"version":"sword","text":"For Poliwag, swimming is easier than walking. The swirl pattern on its belly is actually part of the Pok\u00e9mon\u2019s innards showing through the skin."},{"version":"shield","text":"In rivers with fast-flowing water, this Pok\u00e9mon will cling to a rock by using its thick lips, which act like a suction cup."}],"evo":{"name":"poliwag","level":0,"min_level":null,"trigger":null,"item":null,"held_item":null,"known_move":null,"known_move_type":null,"location":null,"min_affection":null,"min_beauty":null,"min_happiness":null,"needs_overworld_rain":false,"time_of_day":null,"turn_upside_down":false,"evolves_to":[{"name":"poliwhirl","level":1,"min_level":25,"trigger":"level-up","item":null,"held_item":null,"known_move":null,"known_move_type":null,"location":null,"min_affection":null,"min_beauty":null,"min_happiness":null,"needs_overworld_rain":false,"time_of_day":"","turn_upside_down":false,"evolves_to":[{"name":"poliwrath","level":2,"min_level":null,"trigger":"use-item","item":"water-stone","held_item":null,"known_move":null,"known_move_type":null,"location":null,"min_affection":null,"min_beauty":null,"min_happiness":null,"needs_overworld_rain":false,"time_of_day":"","turn_upside_down":false,"evolves_to":[]},{"name":"politoed","level":2,"min_level":null,"trigger":"trade","item":null,"held_item":"kings-rock","known_move":null,"known_move_type":null,"location":null,"min_affection":null,"min_beauty":null,"min_happiness":null,"needs_overworld_rain":false,"time_of_day":"","turn_upside_down":false,"evolves_to":[]}]}]},"sprite":"https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/60.png","shiny":"https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/shiny/60.png","capture":255,"happiness":70,"growth":"medium-slow","gender":4,"hatch":20,