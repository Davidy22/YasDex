2],"machine_sun-moon":[57,58,59,63,92,94,104,113,127,156,164,182,207,213,214,216,218,237,240,244,258,263,280,332,347,374,411,416,421,473,490,496,503,590],"machine_ultra-sun-ultra-moon":[57,58,59,63,92,94,104,113,127,156,164,182,207,213,214,216,218,237,240,244,258,263,280,332,347,374,411,416,421,473,490,496,503,590],"machine_brilliant-diamond-shining-pearl":[57,58,59,63,70,91,94,104,113,127,148,156,164,182,203,207,213,214,231,240,244,249,258,263,264,280,332,347,352,362,374,411,416,421,431,490,503],"tutor_crystal":[58],"xd-purification_xd":[127,204,244,280],"tutor_sword-shield":[812]},"species":"golduck","gen":"generation-i","leg":false,"myth":false,"baby":false,"eggs":["Water 1","Field"],"flavor":[{"version":"red","text":"Often seen swim\u00ad ming elegantly by lake shores. It is often mistaken for the Japanese monster, Kappa."},{"version":"blue","text":"Often seen swim\u00ad ming elegantly by lake shores. It is often mistaken for the Japanese monster, Kappa."},{"version":"yellow","text":"Its slim and long limbs end in broad flippers. They are used for swim\u00ad ming gracefully in lakes."},{"version":"gold","text":"When it swims at full speed using its long, webbed limbs, its fore\u00ad head somehow be\u00ad gins to glow."},{"version":"silver","text":"It appears by waterways at dusk. It may use tele\u00ad kinetic powers if its forehead glows mysteriously."},{"version":"crystal","text":"It swims grace\u00ad fully along on the quiet, slow-moving rivers and lakes of which it is so fond."},{"version":"ruby","text":"The webbed flippers on its forelegs and hind legs and the streamlined body of GOLDUCK give it frightening speed. This POK\u00e9MON is definitely much faster than even the most athletic swimmer."},{"version":"sapphire","text":"GOLDUCK is the fastest swimmer among all POK\u00e9MON. It swims effortlessly, even in a rough, stormy sea. It sometimes rescues people from wrecked ships floundering in high seas."},{"version":"emerald","text":"A GOLDUCK is an adept swimmer. It sometimes joins competitive swimmers in training. It uses psychic powers when its forehead shimmers with light."},{"version":"firered","text":"The forelegs are webbed, helping to make it an adept swimmer. It can be seen swimming elegantly in lakes, etc."},{"version":"leafgreen","text":"Often seen swimming elegantly by lakeshores. It is often mistaken for the Japanese monster Kappa."},{"version":"diamond","text":"A Pok\u00e9mon that lives in lakes. It swims faster than any human swimming champion."},{"version":"pearl","text":"The flippers of its well-developed limbs give it shocking speed. It is the best swimmer among Pok\u00e9mon."},{"version":"platinum","text":"It is seen swimming dynamically and elegantly using its well-developed limbs and flippers."},{"version":"heartgold","text":"When it swims at full speed using its long, webbed limbs, its forehead somehow begins to glow."},{"version":"soulsilver","text":"It appears by waterways at dusk. It may use telekinetic powers if its forehead glows mysteriously."},{"version":"black","text":"It is seen swimming dynamically and elegantly using its well-developed limbs and flippers."},{"version":"white","text":"It is seen swimming dynamically and elegantly using its well-developed limbs and flippers."},{"version":"black-2","text":"When its forehead shines mysteriously, Golduck can use the full extent of its power."},{"version":"white-2","text":"When its forehead shines mysteriously, Golduck can use the full extent of its power."},{"version":"x","text":"It appears by waterways at dusk. It may use telekinetic powers if its forehead glows mysteriously."},{"version":"y","text":"The forelegs are webbed, helping to make it an adept swimmer. It can be seen swimming elegantly in lakes, etc."},{"version":"omega-ruby","text":"The webbed flippers on its forelegs and hind legs and the streamlined body of Golduck give it frightening speed. This Pok\u00e9mon is definitely much faster than even the most athletic swimmer."},{"version":"alpha-sapphire","text":"Golduck is the fastest swimmer among all Pok\u00e9mon. It swims effortlessly, even in a rough, stormy sea. It sometimes rescues people from wrecked ships floundering in high seas."},{"version":"sun","text":"It is said that the red part of its forehead grants supernatural powers to those who possess one, so it was over-hunted in the past."},{"version":"moon","text":"It swims along the banks of lakes and catches fish Pok\u00e9mon. It takes them to the shore and quietly eats them up."},{"version":"ultra-sun","text":"Even fast-swimming fish Pok\u00e9mon can be disabled by Golduck. It brings them to a standstill and seizes them."},{"version":"ultra-moon","text":"A professional swimmer, it can continue swimming for two days straight by waving its long tail skillfully."},{"version":"lets-go-pikachu","text":"Its long, slim limbs end in broad flippers. They are used for swimming gracefully in lakes."},{"version":"lets-go-eevee","text":"Its long, slim limbs end in broad flippers. They are used for swimming gracefully in lakes."},{"version":"sword","text":"This Pok\u00e9mon lives in gently flowing rivers. It paddles through the water with its long limbs, putting its graceful swimming skills on display."},{"version":"shield","text":"Old tales tell of Golduck punishing those that defiled its river. The guilty were dragged into the water and taken away."},{"version":"legends-arceus","text":"Its body is strong, and it has webbing on its hands and feet. Golduck can swim easily through rough seas, clawing its way through the high waves."}],"evo":{"name":"psyduck","level":0,"min_level":null,"trigger":null,"item":null,"held_item":null,"known_move":null,"known_move_type":null,"location":null,"min_affection":null,"min_beauty":null,"min_happiness":null,"needs_overworld_rain":false,"time_of_day":null,"turn_upside_down":false,"evolves_to":[{"name":"golduck","level":1,"min_level":33,"trigger":"level-up","item":null,"held_item":null,"known_move":null,"known_move_