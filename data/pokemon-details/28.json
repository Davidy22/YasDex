],"tutor_platinum":[129,173,189,205,210,282,414],"tutor_black-2-white-2":[162,173,214,231,282,343,414,446],"tutor_omega-ruby-alpha-sapphire":[162,173,231,264,282,343,414,446],"tutor_ultra-sun-ultra-moon":[162,173,231,264,282,343,414,446,707],"tutor_sword-shield":[798,815]},"species":"sandslash","gen":"generation-i","leg":false,"myth":false,"baby":false,"eggs":["Field"],"flavor":[{"version":"red","text":"Curls up into a spiny ball when threatened. It can roll while curled up to attack or escape."},{"version":"blue","text":"Curls up into a spiny ball when threatened. It can roll while curled up to attack or escape."},{"version":"yellow","text":"It is skilled at slashing enemies with its claws. If broken, they start to grow back in a day."},{"version":"gold","text":"In an attempt to hide itself, it will run around at top speed to kick up a blinding dust storm."},{"version":"silver","text":"If it digs at an incredible pace, it may snap off its spikes and claws. They grow back in a day."},{"version":"crystal","text":"Adept at climbing trees, it rolls into a spiny ball, then attacks its enemies from above."},{"version":"ruby","text":"SANDSLASH\u2019s body is covered by tough spikes, which are hardened sections of its hide. Once a year, the old spikes fall out, to be replaced with new spikes that grow out from beneath the old ones."},{"version":"sapphire","text":"SANDSLASH can roll up its body as if it were a ball covered with large spikes. In battle, this POK\u00e9MON will try to make the foe flinch by jabbing it with its spines. It then leaps at the stunned foe to tear wildly with its sharp claws."},{"version":"emerald","text":"It curls up in a ball to protect itself from enemy attacks. It also curls up to prevent heatstroke during the daytime when temperatures rise sharply."},{"version":"firered","text":"It is adept at attacking with the spines on its back and its sharp claws while quickly scurrying about."},{"version":"leafgreen","text":"Curls up into a spiny ball when threatened. It can roll while curled up to attack or escape."},{"version":"diamond","text":"It curls up, then rolls into foes with its back. Its sharp spines inflict severe damage."},{"version":"pearl","text":"It curls up, then rolls into foes with its back. Its sharp spines inflict severe damage."},{"version":"platinum","text":"It curls up, then rolls into foes with its back. Its sharp spines inflict severe damage."},{"version":"heartgold","text":"In an attempt to hide itself, it will run around at top speed to kick up a blinding dust storm."},{"version":"soulsilver","text":"If it digs at an incredible pace, it may snap off its spikes and claws. They grow back in a day."},{"version":"black","text":"It curls up, then rolls into foes with its back. Its sharp spines inflict severe damage."},{"version":"white","text":"It curls up, then rolls into foes with its back. Its sharp spines inflict severe damage."},{"version":"black-2","text":"The spikes on its body are made up of its hardened hide. It rolls up and attacks foes with its spikes."},{"version":"white-2","text":"The spikes on its body are made up of its hardened hide. It rolls up and attacks foes with its spikes."},{"version":"x","text":"If it digs at an incredible pace, it may snap off its spikes and claws. They grow back in a day."},{"version":"y","text":"Curls up into a spiny ball when threatened. It can roll while curled up to attack or escape."},{"version":"omega-ruby","text":"Sandslash\u2019s body is covered by tough spikes, which are hardened sections of its hide. Once a year, the old spikes fall out, to be replaced with new spikes that grow out from beneath the old ones."},{"version":"alpha-sapphire","text":"Sandslash can roll up its body as if it were a ball covered with large spikes. In battle, this Pok\u00e9mon will try to make the foe flinch by jabbing it with its spines. It then leaps at the stunned foe to tear wildly with its sharp claws."},{"version":"sun","text":"Although they are sharp, its claws and spikes often break off. They grow back the next day, so it is not bothered by the temporary loss."},{"version":"moon","text":"It uses its claws to climb trees and then curls its body into a spiny ball, ready to drop onto any prey that appears."},{"version":"ultra-sun","text":"Its claws and horns often break off. The broken claws and horns can be used to carve plows for tilling farm fields."},{"version":"ultra-moon","text":"Thanks to its thick claws, it\u2019s good at climbing trees. There are plenty of Sandslash that park themselves in trees and go right to sleep."},{"version":"lets-go-pikachu","text":"It is skilled at slashing enemies with its claws. If broken, they start to grow back in a day."},{"version":"lets-go-eevee","text":"It is skilled at slashing enemies with its claws. If broken, they start to grow back in a day."},{"version":"sword","text":"The drier the area Sandslash lives in, the harder and smoother the Pok\u00e9mon\u2019s spikes will feel when touched."},{"version":"shield","text":"It climbs trees by hooking on with its sharp claws. Sandslash shares the berries it gathers, dropping them down to Sandshrew waiting below the tree."}],"evo":{"name":"sandshrew","level":0,"min_level":null,"trigger":null,"item":null,"held_item":null,"known_move":null,"known_move_type":null,"location":null,"min_affection":null,"min_beauty":null,"min_happiness":null,"needs_overworld_rain":false,"time_of_day":null,"turn_upside_down":false,"evolves_to":[{"name":"sandslash","level":1,"min_level":22,"trigger":"level-up","item":null,"held_item":null,"known_move":null,"known_move_type":null,"location":null,"min_affection":null,"min_beauty":null,"min_happiness":null,"needs_overworld_rain":false,"time_of_day":"","turn_upside_down":false,"evolves_to":[]}]},"sprite":"https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/28.png","shiny":"https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/shiny/28.png","capture":90,"happiness":70,"growth":"m