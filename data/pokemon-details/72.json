on":[62,109,114,145,229,243,282,321,330,367,392],"egg_sword-shield":[62,109,114,229,243,282,321,367,392],"egg_brilliant-diamond-shining-pearl":[62,109,114,229,243,282,321,330,367,392],"egg_scarlet-violet":[62,109,114,229,243,282,321,367,392],"tutor_platinum":[173,196,282,291],"tutor_heartgold-soulsilver":[173,196,277,282,291]},"species":"tentacool","gen":"generation-i","leg":false,"myth":false,"baby":false,"eggs":["Water 3"],"flavor":[{"version":"red","text":"Drifts in shallow seas. Anglers who hook them by accident are often punished by its stinging acid."},{"version":"blue","text":"Drifts in shallow seas. Anglers who hook them by accident are often punished by its stinging acid."},{"version":"yellow","text":"It can sometimes be found all dry and shriveled up on a beach. Toss it back into the sea to revive it."},{"version":"gold","text":"When the tide goes out, dehydrated TENTACOOL remains can be found washed up on the shore."},{"version":"silver","text":"It drifts aimless\u00ad ly in waves. Very difficult to see in water, it may not be noticed until it stings."},{"version":"crystal","text":"As it floats along on the waves, it uses its toxic feelers to stab anything it touches."},{"version":"ruby","text":"TENTACOOL\u2019s body is largely composed of water. If it is removed from the sea, it dries up like parchment. If this POK\u00e9MON happens to become dehydrated, put it back into the sea."},{"version":"sapphire","text":"TENTACOOL absorbs sunlight and refracts it using water inside its body to convert it into beam energy. This POK\u00e9MON shoots beams from its crystal-like eyes."},{"version":"emerald","text":"Its body is almost entirely composed of water. It ensnares its foe with its two long tentacles, then stabs with the poison stingers at their tips."},{"version":"firered","text":"Its eyes are as transparent as crystals. From them, it shoots mysterious beams of light."},{"version":"leafgreen","text":"Drifts in shallow seas. Anglers who hook them by accident are often punished by their stingers."},{"version":"diamond","text":"Its body is virtually composed of water. It shoots strange beams from its crystal-like eyes."},{"version":"pearl","text":"It drifts in sea currents. Countless fishermen are hurt by its poison stingers."},{"version":"platinum","text":"Because its body is almost entirely composed of water, it shrivels up if it is washed ashore."},{"version":"heartgold","text":"When the tide goes out, dehydrated TENTACOOL remains can be found washed up on the shore."},{"version":"soulsilver","text":"It drifts aimlessly in waves. Very difficult to see in water, it may not be noticed until it stings."},{"version":"black","text":"Because its body is almost entirely composed of water, it shrivels up if it is washed ashore."},{"version":"white","text":"Because its body is almost entirely composed of water, it shrivels up if it is washed ashore."},{"version":"black-2","text":"Because its body is almost entirely composed of water, it shrivels up if it is washed ashore."},{"version":"white-2","text":"Because its body is almost entirely composed of water, it shrivels up if it is washed ashore."},{"version":"x","text":"Its body is virtually composed of water. It shoots strange beams from its crystal-like eyes."},{"version":"y","text":"Drifts in shallow seas. Anglers who hook them by accident are often punished by their stingers."},{"version":"omega-ruby","text":"Tentacool\u2019s body is largely composed of water. If it is removed from the sea, it dries up like parchment. If this Pok\u00e9mon happens to become dehydrated, put it back into the sea."},{"version":"alpha-sapphire","text":"Tentacool absorbs sunlight and refracts it using water inside its body to convert it into beam energy. This Pok\u00e9mon shoots beams from the small round organ above its eyes."},{"version":"sun","text":"They can be found lying dehydrated on beaches, but they are often still alive. When soaked in water, they will revive."},{"version":"moon","text":"It drifts in shallow seas, such as the areas near beaches. If you get bitten or stabbed by its toxic tentacles, rush to the hospital."},{"version":"ultra-sun","text":"It drifts through the sea searching for prey. Its poisonous tentacles break off sometimes, but after a while, they grow back."},{"version":"ultra-moon","text":"Its body is 99% water. The remaining 1% contains the organ that makes its poison."},{"version":"lets-go-pikachu","text":"It can sometimes be found all dry and shriveled up on a beach. Toss it back into the sea to revive it."},{"version":"lets-go-eevee","text":"It can sometimes be found all dry and shriveled up on a beach. Toss it back into the sea to revive it."},{"version":"sword","text":"Tentacool is not a particularly strong swimmer. It drifts across the surface of shallow seas as it searches for prey."},{"version":"shield","text":"This Pok\u00e9mon is mostly made of water. A Tentacool out in the ocean is very hard to spot, because its body blends in with the sea."},{"version":"legends-arceus","text":"They fire beams from the glassy, magenta orbs that resemble eyes atop their heads, and they drift in shallow seas. During low tide, they can sometimes be found on beaches, desiccated."}],"evo":{"name":"tentacool","level":0,"min_level":null,"trigger":null,"item":null,"held_item":null,"known_move":null,"known_move_type":null,"location":null,"min_affection":null,"min_beauty":null,"min_happiness":null,"needs_overworld_rain":false,"time_of_day":null,"turn_upside_down":false,"evolves_to":[{"name":"tentacruel","level":1,"min_level":30,"trigger":"level-up","item":null,"held_item":null,"known_move":null,"known_move_type":null,"location":null,"min_affection":null,"min_beauty":null,"min_happiness":null,"needs_overworld_rain":false,"time_of_day":"","turn_upside_down":false,"evolves_to":[]}]},"sprite":"https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/72.png","shiny":"https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokem