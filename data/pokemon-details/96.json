3,115,148,156,168,182,213,216,218,219,237,240,241,247,259,263,264,269,280,285,289,290,347],"machine_firered-leafgreen":[92,94,104,113,115,148,156,168,182,213,216,218,219,237,240,241,247,259,263,264,269,280,285,289,290,347],"machine_colosseum":[92,94,104,113,115,148,156,168,182,213,216,218,219,237,240,241,247,259,263,264,269,280,285,289,290,347],"machine_xd":[92,94,104,113,115,148,156,168,182,213,216,218,219,237,240,241,247,259,263,264,269,280,285,289,290,347],"egg_gold-silver":[112,113],"egg_crystal":[112,113]},"species":"drowzee","gen":"generation-i","leg":false,"myth":false,"baby":false,"eggs":["humanshape"],"flavor":[{"version":"red","text":"Puts enemies to sleep then eats their dreams. Occasionally gets sick from eating bad dreams."},{"version":"blue","text":"Puts enemies to sleep then eats their dreams. Occasionally gets sick from eating bad dreams."},{"version":"yellow","text":"If you sleep by it all the time, it will sometimes show you dreams it has eaten in the past."},{"version":"gold","text":"If you think that you had a good dream, but you can't remember it, a DROWZEE has probably eaten it."},{"version":"silver","text":"It remembers every dream it eats. It rarely eats the dreams of adults because children's are much tastier."},{"version":"crystal","text":"When it twitches its nose, it can tell where someone is sleeping and what that person is dreaming about."},{"version":"ruby","text":"If your nose becomes itchy while you are sleeping, it\u2019s a sure sign that one of these POK\u00e9MON is standing above your pillow and trying to eat your dream through your nostrils."},{"version":"sapphire","text":"If your nose becomes itchy while you are sleeping, it\u2019s a sure sign that one of these POK\u00e9MON is standing above your pillow and trying to eat your dream through your nostrils."},{"version":"emerald","text":"If your nose becomes itchy while you are sleeping, it\u2019s a sure sign that a DROWZEE is standing above your pillow and trying to eat your dream through your nostrils."},{"version":"firered","text":"A descendent of the legendary animal baku, which is said to eat dreams. It is skilled at hypnotism."},{"version":"leafgreen","text":"Puts enemies to sleep, then eats their dreams. Occasionally gets sick from eating only bad dreams."},{"version":"diamond","text":"It can tell what people are dreaming by sniffing with its big nose. It loves fun dreams."},{"version":"pearl","text":"It can tell what people are dreaming by sniffing with its big nose. It loves fun dreams."},{"version":"platinum","text":"It can tell what people are dreaming by sniffing with its big nose. It loves fun dreams."},{"version":"heartgold","text":"If you think that you had a good dream but you can\u2019t remember it, a DROWZEE has probably eaten it."},{"version":"soulsilver","text":"It remembers every dream it eats. It rarely eats the dreams of adults because children\u2019s are much tastier."},{"version":"black","text":"It can tell what people are dreaming by sniffing with its big nose. It loves fun dreams."},{"version":"white","text":"It can tell what people are dreaming by sniffing with its big nose. It loves fun dreams."},{"version":"black-2","text":"It can tell what people are dreaming by sniffing with its big nose. It loves fun dreams."},{"version":"white-2","text":"It can tell what people are dreaming by sniffing with its big nose. It loves fun dreams."},{"version":"x","text":"Puts enemies to sleep, then eats their dreams. Occasionally gets sick from eating only bad dreams."},{"version":"y","text":"If you think that you had a good dream but you can\u2019t remember it, a Drowzee has probably eaten it."},{"version":"omega-ruby","text":"If your nose becomes itchy while you are sleeping, it\u2019s a sure sign that one of these Pok\u00e9mon is standing above your pillow and trying to eat your dream through your nostrils."},{"version":"alpha-sapphire","text":"If your nose becomes itchy while you are sleeping, it\u2019s a sure sign that one of these Pok\u00e9mon is standing above your pillow and trying to eat your dream through your nostrils."},{"version":"sun","text":"A Pok\u00e9mon that nourishes itself by eating dreams, it is thought to share common ancestry with Munna and Musharna."},{"version":"moon","text":"It finds really fun dreams tasty. When it makes friends with people, it may show them the most delicious dreams it\u2019s ever eaten."},{"version":"ultra-sun","text":"It can be spotted near recreational facilities, intending to eat the pleasant dreams of children who enjoyed themselves there that day."},{"version":"ultra-moon","text":"It puts its prey to sleep and devours their dreams. It seems that bad dreams taste sour, so Drowzee doesn\u2019t particularly like eating them."},{"version":"lets-go-pikachu","text":"If you sleep by it all the time, it will sometimes show you dreams it had eaten in the past."},{"version":"lets-go-eevee","text":"If you sleep by it all the time, it will sometimes show you dreams it had eaten in the past."}],"evo":{"name":"drowzee","level":0,"min_level":null,"trigger":null,"item":null,"held_item":null,"known_move":null,"known_move_type":null,"location":null,"min_affection":null,"min_beauty":null,"min_happiness":null,"needs_overworld_rain":false,"time_of_day":null,"turn_upside_down":false,"evolves_to":[{"name":"hypno","level":1,"min_level":26,"trigger":"level-up","item":null,"held_item":null,"known_move":null,"known_move_type":null,"location":null,"min_affection":null,"min_beauty":null,"min_happiness":null,"needs_overworld_rain":false,"time_of_day":"","turn_upside_down":false,"evolves_to":[]}]},"sprite":"https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/96.png","shiny":"https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/shiny/96.png","capture":190,"happiness":70,"growth":"medium","gender":4,"hatch":20,"ev":{"special_defense":1},"forms":[]}