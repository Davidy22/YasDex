9,496,523,590],"machine_brilliant-diamond-shining-pearl":[53,70,89,91,104,126,153,156,157,164,182,201,203,207,213,214,241,249,263,264,280,317,360,374,397,431,444,446,523]},"species":"geodude","gen":"generation-i","leg":false,"myth":false,"baby":false,"eggs":["mineral"],"flavor":[{"version":"red","text":"Found in fields and mountains. Mistaking them for boulders, people often step or trip on them."},{"version":"blue","text":"Found in fields and mountains. Mistaking them for boulders, people often step or trip on them."},{"version":"yellow","text":"Commonly found near mountain trails, etc. If you step on one by accident, it gets angry."},{"version":"gold","text":"Most people may not notice, but a closer look should reveal that there are many GEODUDE around."},{"version":"silver","text":"It uses its arms to steadily climb steep mountain paths. It swings its fists around if angered."},{"version":"crystal","text":"Proud of their sturdy bodies, they bash against each other in a contest to prove whose is harder."},{"version":"ruby","text":"The longer a GEODUDE lives, the more its edges are chipped and worn away, making it more rounded in appearance. However, this POK\u00e9MON\u2019s heart will remain hard, craggy, and rough always."},{"version":"sapphire","text":"When GEODUDE sleeps deeply, it buries itself halfway into the ground. It will not awaken even if hikers step on it unwittingly. In the morning, this POK\u00e9MON rolls downhill in search of food."},{"version":"emerald","text":"It climbs mountain paths using only the power of its arms. Because they look just like boulders lining paths, hikers may step on them without noticing."},{"version":"firered","text":"Its round form makes it easy to pick up. Some people have used them to hurl at each other in a snowball fight."},{"version":"leafgreen","text":"Found in fields and mountains. Mistaking them for boulders, people often step or trip on them."},{"version":"diamond","text":"Many live on mountain trails and remain half buried while keeping an eye on climbers."},{"version":"pearl","text":"It is impossible to distinguish from rocks. It slams against others in contests of hardness."},{"version":"platinum","text":"At rest, it looks just like a rock. Carelessly stepping on it will make it swing its fists angrily."},{"version":"heartgold","text":"Most people may not notice, but a closer look should reveal that there are many GEODUDE around."},{"version":"soulsilver","text":"It uses its arms to steadily climb steep mountain paths. It swings its fists around if angered."},{"version":"black","text":"At rest, it looks just like a rock. Carelessly stepping on it will make it swing its fists angrily."},{"version":"white","text":"At rest, it looks just like a rock. Carelessly stepping on it will make it swing its fists angrily."},{"version":"black-2","text":"At rest, it looks just like a rock. Carelessly stepping on it will make it swing its fists angrily."},{"version":"white-2","text":"At rest, it looks just like a rock. Carelessly stepping on it will make it swing its fists angrily."},{"version":"x","text":"Found in fields and mountains. Mistaking them for boulders, people often step or trip on them."},{"version":"y","text":"It is impossible to distinguish from rocks. It slams against others in contests of hardness."},{"version":"omega-ruby","text":"The longer a Geodude lives, the more its edges are chipped and worn away, making it more rounded in appearance. However, this Pok\u00e9mon\u2019s heart will remain hard, craggy, and rough always."},{"version":"alpha-sapphire","text":"When Geodude sleeps deeply, it buries itself halfway into the ground. It will not awaken even if hikers step on it unwittingly. In the morning, this Pok\u00e9mon rolls downhill in search of food."},{"version":"sun","text":"Its round body makes it easy to pick up, but it is hard and heavy. It\u2019s dangerous to play with them as if they were snowballs."},{"version":"moon","text":"There are plenty of them to be found along any road. A scholar with too much free time once counted a hundred of them along a single route."},{"version":"ultra-sun","text":"Geodude that have lived a long life have had all their edges smoothed out until they\u2019re totally round. They also have a calm, quiet disposition."},{"version":"ultra-moon","text":"It uses both hands to climb precipitous cliffs. People who see it in action have been known to take up bouldering."},{"version":"lets-go-pikachu","text":"Commonly found near mountain trails and the like. If you step on one by accident, it gets angry."},{"version":"lets-go-eevee","text":"Commonly found near mountain trails and the like. If you step on one by accident, it gets angry."},{"version":"legends-arceus","text":"Makes its home in mountainous regions, using its arms to climb along harsh mountain roads. Can be troublesome\u2014carelessly kicking one will cause it to fly into a rage and chase after you."}],"evo":{"name":"geodude","level":0,"min_level":null,"trigger":null,"item":null,"held_item":null,"known_move":null,"known_move_type":null,"location":null,"min_affection":null,"min_beauty":null,"min_happiness":null,"needs_overworld_rain":false,"time_of_day":null,"turn_upside_down":false,"evolves_to":[{"name":"graveler","level":1,"min_level":25,"trigger":"level-up","item":null,"held_item":null,"known_move":null,"known_move_type":null,"location":null,"min_affection":null,"min_beauty":null,"min_happiness":null,"needs_overworld_rain":false,"time_of_day":"","turn_upside_down":false,"evolves_to":[{"name":"golem","level":2,"min_level":null,"trigger":"trade","item":null,"held_item":null,"known_move":null,"known_move_type":null,"location":null,"min_affection":null,"min_beauty":null,"min_happiness":null,"needs_overworld_rain":false,"time_of_day":"","turn_upside_down":false,"evolves_to":[]}]}]},"sprite":"https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/74.png","shiny":"https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/p