d \u201cthe cleaner of the desert.\u201d"},{"version":"sword","text":"The desert gets cold at night, so when the sun sets, this Pok\u00e9mon burrows deep into the sand and sleeps until sunrise."},{"version":"shield","text":"Sandile is small, but its legs and lower body are powerful. Pushing sand aside as it goes, Sandile moves through the desert as if it\u2019s swimming."}],"evo":{"name":"sandile","level":0,"min_level":null,"trigger":null,"item":null,"held_item":null,"known_move":null,"known_move_type":null,"location":null,"min_affection":null,"min_beauty":null,"min_happiness":null,"needs_overworld_rain":false,"time_of_day":null,"turn_upside_down":false,"evolves_to":[{"name":"krokorok","level":1,"min_level":29,"trigger":"level-up","item":null,"held_item":null,"known_move":null,"known_move_type":null,"location":null,"min_affection":null,"min_beauty":null,"min_happiness":null,"needs_overworld_rain":false,"time_of_day":"","turn_upside_down":false,"evolves_to":[{"name":"krookodile","level":2,"min_level":40,"trigger":"level-up","item":null,"held_item":null,"known_move":null,"known_move_type":null,"location":null,"min_affection":null,"min_beauty":null,"min_happiness":null,"needs_overworld_rain":false,"time_of_day":"","turn_upside_down":false,"evolves_to":[]}]}]},"sprite":"https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/551.png","shiny":"https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/shiny/551.png","capture":180,"happiness":70,"growth":"medium-slow","gender":4,"hatch":20,"ev":{"attack":1},"forms":[]}