ainers."},{"version":"ultra-sun","text":"It follows Pangoro around like a henchman. When Pancham makes a big mistake, its leaf gets taken away."},{"version":"ultra-moon","text":"It\u2019s desperate to intimidate its opponents. Be nice and pretend to be scared if you catch it glaring at you intensely."},{"version":"sword","text":"It chooses a Pangoro as its master and then imitates its master\u2019s actions. This is how it learns to battle and hunt for prey."},{"version":"shield","text":"Wanting to make sure it\u2019s taken seriously, Pancham\u2019s always giving others a glare. But if it\u2019s not focusing, it ends up smiling."}],"evo":{"name":"pancham","level":0,"min_level":null,"trigger":null,"item":null,"held_item":null,"known_move":null,"known_move_type":null,"location":null,"min_affection":null,"min_beauty":null,"min_happiness":null,"needs_overworld_rain":false,"time_of_day":null,"turn_upside_down":false,"evolves_to":[{"name":"pangoro","level":1,"min_level":32,"trigger":"level-up","item":null,"held_item":null,"known_move":null,"known_move_type":null,"location":null,"min_affection":null,"min_beauty":null,"min_happiness":null,"needs_overworld_rain":false,"time_of_day":"","turn_upside_down":false,"evolves_to":[]}]},"sprite":"https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/674.png","shiny":"https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/shiny/674.png","capture":220,"happiness":70,"growth":"medium","gender":4,"hatch":25,"ev":{"attack":1},"forms":[]}