ure in the atmosphere."},{"version":"shield","text":"It can instantly freeze moisture in the atmosphere. It uses this power to freeze its foes."},{"version":"legends-arceus","text":"It covers its body with an armor of ice harder than steel. Uses its breath to freeze prey, which it then devours as if they were frozen desserts."}],"evo":{"name":"snorunt","level":0,"min_level":null,"trigger":null,"item":null,"held_item":null,"known_move":null,"known_move_type":null,"location":null,"min_affection":null,"min_beauty":null,"min_happiness":null,"needs_overworld_rain":false,"time_of_day":null,"turn_upside_down":false,"evolves_to":[{"name":"glalie","level":1,"min_level":42,"trigger":"level-up","item":null,"held_item":null,"known_move":null,"known_move_type":null,"location":null,"min_affection":null,"min_beauty":null,"min_happiness":null,"needs_overworld_rain":false,"time_of_day":"","turn_upside_down":false,"evolves_to":[]},{"name":"froslass","level":1,"min_level":null,"trigger":"use-item","item":"dawn-stone","held_item":null,"known_move":null,"known_move_type":null,"location":null,"min_affection":null,"min_beauty":null,"min_happiness":null,"needs_overworld_rain":false,"time_of_day":"","turn_upside_down":false,"evolves_to":[]}]},"sprite":"https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/362.png","shiny":"https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/shiny/362.png","capture":75,"happiness":70,"growth":"medium","gender":4,"hatch":20,"ev":{"hp":2},"forms":[{"id":10074,"name":"glalie-mega","sprite":"https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/10074.png"}]}