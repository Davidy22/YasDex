u00e9mon is said to be the desert spirit."},{"version":"sun","text":"The flapping of its wings sounds something like singing. Those lured by the sound are enveloped in a sandstorm, becoming Flygon\u2019s prey."},{"version":"moon","text":"This Pok\u00e9mon hides in the heart of sandstorms it creates and seldom appears where people can see it."},{"version":"ultra-sun","text":"By flapping their wings, Flygon cause sandstorms that conceal Krookodile. The team then splits the prey they catch."},{"version":"ultra-moon","text":"People continue to have their hearts stolen by its enchanting songs and find themselves stranded in the desert."},{"version":"sword","text":"This Pok\u00e9mon hides in the heart of sandstorms it creates and seldom appears where people can see it."},{"version":"shield","text":"It is nicknamed the Desert Spirit because the flapping of its wings sounds like a woman singing."}],"evo":{"name":"trapinch","level":0,"min_level":null,"trigger":null,"item":null,"held_item":null,"known_move":null,"known_move_type":null,"location":null,"min_affection":null,"min_beauty":null,"min_happiness":null,"needs_overworld_rain":false,"time_of_day":null,"turn_upside_down":false,"evolves_to":[{"name":"vibrava","level":1,"min_level":35,"trigger":"level-up","item":null,"held_item":null,"known_move":null,"known_move_type":null,"location":null,"min_affection":null,"min_beauty":null,"min_happiness":null,"needs_overworld_rain":false,"time_of_day":"","turn_upside_down":false,"evolves_to":[{"name":"flygon","level":2,"min_level":45,"trigger":"level-up","item":null,"held_item":null,"known_move":null,"known_move_type":null,"location":null,"min_affection":null,"min_beauty":null,"min_happiness":null,"needs_overworld_rain":false,"time_of_day":"","turn_upside_down":false,"evolves_to":[]}]}]},"sprite":"https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/330.png","shiny":"https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/shiny/330.png","capture":4