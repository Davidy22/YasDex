590],"machine_brilliant-diamond-shining-pearl":[46,53,63,70,89,91,104,126,153,156,157,164,182,201,203,207,213,214,241,249,263,264,280,317,360,374,397,411,416,431,444,446,523],"tutor_crystal":[53]},"species":"golem","gen":"generation-i","leg":false,"myth":false,"baby":false,"eggs":["Mineral"],"flavor":[{"version":"red","text":"Its boulder-like body is extremely hard. It can easily withstand dynamite blasts without damage."},{"version":"blue","text":"Its boulder-like body is extremely hard. It can easily withstand dynamite blasts without damage."},{"version":"yellow","text":"Once it sheds its skin, its body turns tender and whitish. Its hide hardens when it's exposed to air."},{"version":"gold","text":"It sheds its skin once a year. The discarded shell immediately hard\u00ad ens and crumbles away."},{"version":"silver","text":"It is capable of blowing itself up. It uses this explosive force to jump from mountain to mountain."},{"version":"crystal","text":"Its rock-like body is so durable, even high-powered dynamite blasts fail to scratch its rugged hide."},{"version":"ruby","text":"GOLEM live up on mountains. If there is a large earthquake, these POK\u00e9MON will come rolling down off the mountains en masse to the foothills below."},{"version":"sapphire","text":"GOLEM is known for rolling down from mountains. To prevent them from rolling into the homes of people downhill, grooves have been dug into the sides of mountains to serve as guideways for diverting this POK\u00e9MON\u2019s course."},{"version":"emerald","text":"It is said to live in volcanic craters on mountain peaks. Once a year, it sheds its hide and grows larger. The shed hide crumbles and returns to the soil."},{"version":"firered","text":"It is enclosed in a hard shell that is as rugged as slabs of rock. It sheds skin once a year to grow larger."},{"version":"leafgreen","text":"Its boulder-like body is extremely hard. It can easily withstand dynamite blasts without taking damage."},{"version":"diamond","text":"It sheds its hide once a year. Its boulderlike body is so tough, even dynamite can\u2019t harm it."},{"version":"pearl","text":"It tumbles down mountains, leaving grooves from peak to base. Stay clear of these grooves."},{"version":"platinum","text":"Even dynamite can\u2019t harm its hard, boulderlike body. It sheds its hide just once a year."},{"version":"heartgold","text":"It sheds its skin once a year. The discarded shell immediately hardens and crumbles away."},{"version":"soulsilver","text":"It is capable of blowing itself up. It uses this explosive force to jump from mountain to mountain."},{"version":"black","text":"Even dynamite can\u2019t harm its hard, boulderlike body. It sheds its hide just once a year."},{"version":"white","text":"Even dynamite can\u2019t harm its hard, boulderlike body. It sheds its hide just once a year."},{"version":"black-2","text":"Even dynamite can\u2019t harm its hard, boulder-like body. It sheds its hide just once a year."},{"version":"white-2","text":"Even dynamite can\u2019t harm its hard, boulder-like body. It sheds its hide just once a year."},{"version":"x","text":"It tumbles down mountains, leaving grooves from peak to base. Stay clear of these grooves."},{"version":"y","text":"Even dynamite can\u2019t harm its hard, boulder-like body. It sheds its hide just once a year."},{"version":"omega-ruby","text":"Golem live up on mountains. If there is a large earthquake, these Pok\u00e9mon will come rolling down off the mountains en masse to the foothills below."},{"version":"alpha-sapphire","text":"Golem is known for rolling down from mountains. To prevent them from rolling into the homes of people downhill, grooves have been dug into the sides of mountains to serve as guideways for diverting this Pok\u00e9mon\u2019s course."},{"version":"sun","text":"Its body can survive dynamite blasts without a single scratch, but it hates rain and humidity."},{"version":"moon","text":"Once a year, this Pok\u00e9mon molts, and its shed shell returns to the soil. This process creates enriched soil, so farmers collect the shells."},{"version":"ultra-sun","text":"When Golem grow old, they stop shedding their shells. Those that have lived a long, long time have shells green with moss."},{"version":"ultra-moon","text":"It detonates its own body. The power from that explosion can propel it up steep mountain paths with amazing speed."},{"version":"lets-go-pikachu","text":"Once it sheds its skin, its body turns tender and whitish. Its hide hardens when it\u2019s exposed to air."},{"version":"lets-go-eevee","text":"Once it sheds its skin, its body turns tender and whitish. Its hide hardens when it\u2019s exposed to air."},{"version":"legends-arceus","text":"The rocklike shell is shed each year. The cast-off shell then crumbles, reverting to a mass of soil, which can be spread across fields to promote crop growth."}],"evo":{"name":"geodude","level":0,"min_level":null,"trigger":null,"item":null,"held_item":null,"known_move":null,"known_move_type":null,"location":null,"min_affection":null,"min_beauty":null,"min_happiness":null,"needs_overworld_rain":false,"time_of_day":null,"turn_upside_down":false,"evolves_to":[{"name":"graveler","level":1,"min_level":25,"trigger":"level-up","item":null,"held_item":null,"known_move":null,"known_move_type":null,"location":null,"min_affection":null,"min_beauty":null,"min_happiness":null,"needs_overworld_rain":false,"time_of_day":"","turn_upside_down":false,"evolves_to":[{"name":"golem","level":2,"min_level":null,"trigger":"trade","item":null,"held_item":null,"known_move":null,"known_move_type":null,"location":null,"min_affection":null,"min_beauty":null,"min_happiness":null,"needs_overworld_rain":false,"time_of_day":"","turn_upside_down":false,"evolves_to":[]}]}]},"sprite":"https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/76.png","shiny":"https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/shiny/76.png","capture":45,"happiness":70,"g