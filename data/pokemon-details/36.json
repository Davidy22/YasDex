violet":[[118,1],[309,1],[585,1],[791,1]],"tutor_sword-shield":[800,802,814]},"species":"clefable","gen":"generation-i","leg":false,"myth":false,"baby":false,"eggs":["Fairy"],"flavor":[{"version":"red","text":"A timid fairy POK\u00e9MON that is rarely seen. It will run and hide the moment it senses people."},{"version":"blue","text":"A timid fairy POK\u00e9MON that is rarely seen. It will run and hide the moment it senses people."},{"version":"yellow","text":"They appear to be very protective of their own world. It is a kind of fairy, rarely seen by people."},{"version":"gold","text":"With its acute hearing, it can pick up sounds from far away. It usually hides in quiet places."},{"version":"silver","text":"Its very sensitive ears lets it dis\u00ad tinguish distant sounds. As a re\u00ad sult, it prefers quiet places."},{"version":"crystal","text":"Said to live in quiet, remote mountains, this type of fairy has a strong aversion to being seen."},{"version":"ruby","text":"CLEFABLE moves by skipping lightly as if it were flying using its wings. Its bouncy step lets it even walk on water. It is known to take strolls on lakes on quiet, moonlit nights."},{"version":"sapphire","text":"CLEFABLE moves by skipping lightly as if it were flying using its wings. Its bouncy step lets it even walk on water. It is known to take strolls on lakes on quiet, moonlit nights."},{"version":"emerald","text":"A CLEFABLE uses its wings to skip lightly  as if it were flying. Its bouncy step lets it even walk on water. On quiet, moonlit nights, it strolls on lakes."},{"version":"firered","text":"It has an acute sense of hearing. It can easily hear a pin being dropped nearly 1,100 yards away."},{"version":"leafgreen","text":"A timid fairy POK\u00e9MON that is rarely seen, it will run and hide the moment it senses people."},{"version":"diamond","text":"Rarely seen by people, it is said to be drawn by the full moon to play at deserted lakes."},{"version":"pearl","text":"Its hearing is so acute it can hear a pin drop over half a mile away. It lives on quiet mountains."},{"version":"platinum","text":"It is very wary and rarely shows itself to people. Its ears can hear a pin drop over half a mile away."},{"version":"heartgold","text":"With its acute hearing, it can pick up sounds from far away. It usually hides in quiet places."},{"version":"soulsilver","text":"Its very sensitive ears let it distinguish distant sounds. As a result, it prefers quiet places."},{"version":"black","text":"It is very wary and rarely shows itself to people. Its ears can hear a pin drop over half a mile away."},{"version":"white","text":"It is very wary and rarely shows itself to people. Its ears can hear a pin drop over half a mile away."},{"version":"black-2","text":"Their ears are sensitive enough to hear a pin drop from over a mile away, so they\u2019re usually found in quiet places."},{"version":"white-2","text":"Their ears are sensitive enough to hear a pin drop from over a mile away, so they\u2019re usually found in quiet places."},{"version":"x","text":"Its hearing is so acute it can hear a pin drop over half a mile away. It lives on quiet mountains."},{"version":"y","text":"A timid fairy Pok\u00e9mon that is rarely seen, it will run and hide the moment it senses people."},{"version":"omega-ruby","text":"Clefable moves by skipping lightly as if it were flying using its wings. Its bouncy step lets it even walk on water. It is known to take strolls on lakes on quiet, moonlit nights."},{"version":"alpha-sapphire","text":"Clefable moves by skipping lightly as if it were flying using its wings. Its bouncy step lets it even walk on water. It is known to take strolls on lakes on quiet, moonlit nights."},{"version":"sun","text":"They don\u2019t like to reveal themselves in front of people. They live quietly in packs deep in the mountains."},{"version":"moon","text":"According to tradition, people who see a pair of Clefable skipping by can look forward to a happy marriage."},{"version":"ultra-sun","text":"It can\u2019t help but hear a pin drop from over half a mile away, so it lives deep in the mountains where there aren\u2019t many people or Pok\u00e9mon."},{"version":"ultra-moon","text":"Some scientists believe that it gazes intently at the sky on nights with a full moon because it\u2019s homesick."},{"version":"lets-go-pikachu","text":"They appear to be very protective of their own world. It is a kind of fairy, rarely seen by people."},{"version":"lets-go-eevee","text":"They appear to be very protective of their own world. It is a kind of fairy, rarely seen by people."},{"version":"sword","text":"A timid fairy Pok\u00e9mon that is rarely seen, it will run and hide the moment it senses people."},{"version":"shield","text":"Their ears are sensitive enough to hear a pin drop from over a mile away, so they\u2019re usually found in quiet places."},{"version":"legends-arceus","text":"Legend says that on clear, quiet nights, it listens for the voices of its kin living on the moon. I, too, often think of my homeland, so far away."}],"evo":{"name":"cleffa","level":0,"min_level":null,"trigger":null,"item":null,"held_item":null,"known_move":null,"known_move_type":null,"location":null,"min_affection":null,"min_beauty":null,"min_happiness":null,"needs_overworld_rain":false,"time_of_day":null,"turn_upside_down":false,"evolves_to":[{"name":"clefairy","level":1,"min_level":null,"trigger":"level-up","item":null,"held_item":null,"known_move":null,"known_move_type":null,"location":null,"min_affection":null,"min_beauty":null,"min_happiness":160,"needs_overworld_rain":false,"time_of_day":"","turn_upside_down":false,"evolves_to":[{"name":"clefable","level":2,"min_level":null,"trigger":"use-item","item":"moon-stone","held_item":null,"known_move":null,"known_move_type":null,"location":null,"min_affection":null,"min_beauty":null,"min_happiness":null,"needs_overworld_rain":false,"time_of_day":"","turn_upside_down":false,"evolves_to":[]}]}]},"sprite":"https://raw.githu